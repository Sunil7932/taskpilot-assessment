# ---------------------------------------------------------------------------
# TaskPilot configuration. Copy to `.env` and adjust. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Environment ----------------------------------------------------------
# "development" or "production". In production the app REFUSES to start with the
# insecure default API_KEY below (fail-closed).
ENVIRONMENT=development

# --- Database -------------------------------------------------------------
# Async SQLAlchemy URL (asyncpg driver). Host `db` matches the compose service.
DATABASE_URL=postgresql+asyncpg://taskpilot:taskpilot@db:5432/taskpilot

# Postgres container bootstrap credentials (used by the `db` service only).
POSTGRES_USER=taskpilot
POSTGRES_PASSWORD=taskpilot
POSTGRES_DB=taskpilot

# Connection pool tuning.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# --- API auth -------------------------------------------------------------
# Shared secret required in the `X-API-Key` header on every /tasks request.
# Generate a strong value for production: `openssl rand -hex 32`.
API_KEY=change-me-in-production

# Comma-separated allowed CORS origins. Empty = CORS disabled (correct for a
# server-to-server API). Example: https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=

# --- Worker tuning --------------------------------------------------------
# How often (seconds) the worker scans for due tasks.
WORKER_POLL_INTERVAL_SECONDS=60
# Max retries before a task is dead-lettered (retry_count reaches this value).
MAX_RETRIES=3
# Exponential backoff base (seconds): delay = BASE * 2 ** (attempt - 1).
RETRY_BACKOFF_BASE_SECONDS=60
# Max tasks claimed per worker tick (bounds a single transaction).
WORKER_BATCH_SIZE=20
# How many claimed tasks execute concurrently per tick.
WORKER_CONCURRENCY=5
# Hard per-task execution cap (seconds); exceeding it counts as a failure.
EXECUTION_TIMEOUT_SECONDS=30
# Tasks stuck in `running` longer than this are reclaimed (e.g. worker crashed).
RUNNING_TASK_TIMEOUT_SECONDS=300
# Port the worker process exposes its Prometheus metrics on.
WORKER_METRICS_PORT=9100

# --- App ------------------------------------------------------------------
# Tighten log verbosity in production (INFO recommended).
LOG_LEVEL=INFO
# Max accepted size of the JSON `payload` field, in bytes.
MAX_PAYLOAD_BYTES=65536
# Hard ceiling on the whole request body (bytes); rejected with 413 up front.
MAX_REQUEST_BYTES=1048576
