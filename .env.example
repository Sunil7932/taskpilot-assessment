# ---------------------------------------------------------------------------
# TaskPilot configuration. Copy to `.env` and adjust. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Async SQLAlchemy URL (asyncpg driver). Host `db` matches the compose service.
DATABASE_URL=postgresql+asyncpg://taskpilot:taskpilot@db:5432/taskpilot

# Postgres container bootstrap credentials (used by the `db` service only).
POSTGRES_USER=taskpilot
POSTGRES_PASSWORD=taskpilot
POSTGRES_DB=taskpilot

# --- API auth -------------------------------------------------------------
# Shared secret required in the `X-API-Key` header on every /tasks request.
# Generate a strong value for production, e.g. `openssl rand -hex 32`.
API_KEY=change-me-in-production

# --- Worker tuning --------------------------------------------------------
# How often (seconds) the worker scans for due tasks.
WORKER_POLL_INTERVAL_SECONDS=60
# Max retries before a task is dead-lettered (retry_count reaches this value).
MAX_RETRIES=3
# Exponential backoff base (seconds): delay = BASE * 2 ** retry_count.
RETRY_BACKOFF_BASE_SECONDS=60
# Max tasks claimed per worker tick (bounds a single transaction).
WORKER_BATCH_SIZE=20

# --- App ------------------------------------------------------------------
# Tighten log verbosity in production (INFO recommended).
LOG_LEVEL=INFO
# Max accepted size of the JSON `payload` field, in bytes.
MAX_PAYLOAD_BYTES=65536
